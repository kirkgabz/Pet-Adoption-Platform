# Copy this file to .env and fill in real local values.
# Google Cloud OAuth setup:
# Authorized JavaScript origins:
#   http://127.0.0.1:8000
#   http://localhost:8000
# Authorized redirect URIs:
#   http://127.0.0.1:8000/accounts/google/login/callback/
#   http://localhost:8000/accounts/google/login/callback/
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,pet-adoption-platform-woad.vercel.app
DJANGO_CSRF_TRUSTED_ORIGINS=https://pet-adoption-platform-woad.vercel.app
DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENWEATHER_API_KEY=
